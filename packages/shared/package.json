{
  "name": "@proto-collab/shared",
  "version": "0.1.0",
  "description": "Shared primitives behind the prototype-collab widgets: a Shadow-DOM host, a CSV parser, and common types. Inlined into @proto-collab/nav and @proto-collab/annotations; published for direct reuse.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laura-flugga/prototype-collab-tools.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/laura-flugga/prototype-collab-tools/tree/main/packages/shared#readme",
  "bugs": "https://github.com/laura-flugga/prototype-collab-tools/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "keywords": [
    "shadow-dom",
    "csv",
    "widget",
    "prototype",
    "framework-agnostic"
  ],
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
