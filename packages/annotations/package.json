{
  "name": "@proto-collab/annotations",
  "version": "0.1.0",
  "description": "Drop-in, framework-agnostic prototype annotations: labelled callouts anchored to UI elements, authored in a Google Sheet. Read-only design→engineering handoff.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/annotations.iife.js",
  "jsdelivr": "./dist/annotations.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laura-flugga/prototype-collab-tools.git",
    "directory": "packages/annotations"
  },
  "homepage": "https://github.com/laura-flugga/prototype-collab-tools/tree/main/packages/annotations#readme",
  "bugs": "https://github.com/laura-flugga/prototype-collab-tools/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "keywords": [
    "prototype",
    "annotation",
    "callout",
    "widget",
    "shadow-dom",
    "preact",
    "google-sheets",
    "framework-agnostic"
  ],
  "dependencies": {
    "@floating-ui/dom": "^1.6.13",
    "@preact/signals": "^1.3.1",
    "preact": "^10.25.1"
  },
  "devDependencies": {
    "@proto-collab/shared": "*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
