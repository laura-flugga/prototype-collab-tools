{
  "name": "annotations",
  "version": "0.1.0",
  "description": "Drop-in, framework-agnostic prototype annotations: labelled callouts anchored to UI elements, authored in a Google Sheet. Read-only design→engineering handoff.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/annotations.iife.js",
  "jsdelivr": "./dist/annotations.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": ["prototype", "annotation", "callout", "widget", "shadow-dom", "preact", "google-sheets", "framework-agnostic"],
  "dependencies": {
    "@floating-ui/dom": "^1.6.13",
    "@preact/signals": "^1.3.1",
    "@proto-collab/shared": "*",
    "preact": "^10.25.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
