{
  "name": "@proto-collab/nav",
  "version": "0.1.0",
  "description": "Drop-in, framework-agnostic prototype navigator: a flow gallery + persistent Menu button for deep-linking across web prototype flows.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/proto-nav.iife.js",
  "jsdelivr": "./dist/proto-nav.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laura-flugga/prototype-collab-tools.git",
    "directory": "packages/proto-nav"
  },
  "homepage": "https://github.com/laura-flugga/prototype-collab-tools/tree/main/packages/proto-nav#readme",
  "bugs": "https://github.com/laura-flugga/prototype-collab-tools/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "keywords": ["prototype", "navigation", "deep-link", "widget", "shadow-dom", "preact", "framework-agnostic"],
  "dependencies": {
    "@preact/signals": "^1.3.1",
    "preact": "^10.25.1"
  },
  "devDependencies": {
    "@proto-collab/shared": "*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
